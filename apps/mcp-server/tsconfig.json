{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "dist",
    "noEmit": false,
    "declaration": true,
    "composite": true,
    "allowImportingTsExtensions": false,
    "lib": ["ES2022"],
    "jsx": "preserve",
    "moduleResolution": "node16",
    "module": "Node16"
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
